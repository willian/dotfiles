#!/bin/sh

# Convert an MP4 to a high-quality GIF using a palette
#
# gif input.mp4

if ! command -v ffmpeg >/dev/null 2>&1; then
  echo >&2 "Error: ffmpeg is not installed. Install it with: brew install ffmpeg"
  exit 1
fi

if ! command -v gum >/dev/null 2>&1; then
  echo >&2 "Error: gum is not installed. Install it with: brew install gum"
  exit 1
fi

if [ -z "$1" ]; then
  echo >&2 "Usage: gif <input.mp4>"
  exit 1
fi

input="$1"
dir="$(dirname "$input")"
base="$(basename "$input" .mp4)"
palette="$(mktemp /tmp/palette-XXXXXX.png)"
output="${dir}/${base}.gif"

gum spin --spinner minidot --title "Generating palette..." -- \
  ffmpeg -y -i "$input" \
    -vf "fps=10,scale=1920:1080:flags=lanczos,palettegen" \
    "$palette"

gum spin --spinner minidot --title "Converting to GIF..." -- \
  ffmpeg -y -i "$input" -i "$palette" \
    -filter_complex "fps=10,scale=1920:1080:flags=lanczos[x];[x][1:v]paletteuse=dither=bayer:bayer_scale=5" \
    "$output"

rm -f "$palette"
